{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"customDuotone": true,
			"customGradient": true,
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				},
				{
					"slug": "foreground",
					"color": "#383b43",
					"name": "Foreground"
				},
				{
					"slug": "card",
					"color": "#ffffff",
					"name": "Card"
				},
				{
					"slug": "card-foreground",
					"color": "#383b43",
					"name": "Card Foreground"
				},
				{
					"slug": "popover",
					"color": "#ffffff",
					"name": "Popover"
				},
				{
					"slug": "popover-foreground",
					"color": "#383b43",
					"name": "Popover Foreground"
				},
				{
					"slug": "primary",
					"color": "#1ecad3",
					"name": "Primary"
				},
				{
					"slug": "primary-foreground",
					"color": "#ffffff",
					"name": "Primary Foreground"
				},
				{
					"slug": "secondary",
					"color": "#2c8d9d",
					"name": "Secondary"
				},
				{
					"slug": "secondary-foreground",
					"color": "#ffffff",
					"name": "Secondary Foreground"
				},
				{
					"slug": "muted",
					"color": "#f3f4f6",
					"name": "Muted"
				},
				{
					"slug": "muted-foreground",
					"color": "#666666",
					"name": "Muted Foreground"
				},
				{
					"slug": "accent",
					"color": "#2c8d9d",
					"name": "Accent"
				},
				{
					"slug": "accent-foreground",
					"color": "#ffffff",
					"name": "Accent Foreground"
				},
				{
					"slug": "destructive",
					"color": "#e7000b",
					"name": "Destructive"
				},
				{
					"slug": "destructive-foreground",
					"color": "#ffffff",
					"name": "Destructive Foreground"
				},
				{
					"slug": "border",
					"color": "#d1d5db",
					"name": "Border"
				},
				{
					"slug": "input",
					"color": "#d1d5db",
					"name": "Input"
				},
				{
					"slug": "ring",
					"color": "#1ecad3",
					"name": "Ring"
				},
				{
					"slug": "chart-1",
					"color": "#1ecad3",
					"name": "Chart 1"
				},
				{
					"slug": "chart-2",
					"color": "#2c8d9d",
					"name": "Chart 2"
				},
				{
					"slug": "chart-3",
					"color": "#383b43",
					"name": "Chart 3"
				},
				{
					"slug": "chart-4",
					"color": "#666666",
					"name": "Chart 4"
				},
				{
					"slug": "chart-5",
					"color": "#bfc4c9",
					"name": "Chart 5"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"fluid": false,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Display (Plus Jakarta Sans)",
					"fontFamily": "\"Plus Jakarta Sans\", ui-sans-serif, system-ui, sans-serif"
				},
				{
					"slug": "body",
					"name": "Body (Graphik Trial)",
					"fontFamily": "\"Graphik Trial\", ui-sans-serif, system-ui, sans-serif"
				},
				{
					"slug": "sans",
					"name": "Sans",
					"fontFamily": "\"Graphik Trial\", ui-sans-serif, system-ui, sans-serif"
				},
				{
					"slug": "serif",
					"name": "Serif",
					"fontFamily": "ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
				}
			]
		},
		"layout": {
			"contentSize": "64rem",
			"wideSize": "80rem"
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingScale": {
				"steps": 0,
				"unit": "rem"
			}
		},
		"border": {
			"radius": true,
			"radiusSizes": [
				{
					"slug": "sm",
					"name": "Small",
					"size": "0.375rem"
				},
				{
					"slug": "md",
					"name": "Medium",
					"size": "0.5rem"
				},
				{
					"slug": "lg",
					"name": "Large",
					"size": "0.625rem"
				},
				{
					"slug": "xl",
					"name": "Extra Large",
					"size": "0.875rem"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1rem",
			"lineHeight": "1.6"
		}
	}
}
