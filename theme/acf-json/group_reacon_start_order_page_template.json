{
	"key": "group_reacon_start_order_page_template",
	"title": "Start an Order Page Template Content",
	"fields": [
		{
			"key": "field_so_tab_hero",
			"label": "Hero",
			"name": "",
			"type": "tab",
			"placement": "top",
			"endpoint": 0
		},
		{
			"key": "field_so_enable_hero",
			"label": "Enable hero section",
			"name": "start_order_enable_hero_section",
			"type": "true_false",
			"default_value": 1,
			"ui": 1
		},
		{
			"key": "field_so_hero_group",
			"label": "Hero content",
			"name": "start_order_hero",
			"type": "group",
			"layout": "block",
			"conditional_logic": [
				[
					{
						"field": "field_so_enable_hero",
						"operator": "==",
						"value": "1"
					}
				]
			],
			"sub_fields": [
				{
					"key": "field_so_hero_eyebrow",
					"label": "Eyebrow (upper label)",
					"name": "hero_eyebrow",
					"type": "text",
					"required": 1
				},
				{
					"key": "field_so_hero_heading",
					"label": "Heading (H1)",
					"name": "hero_heading",
					"type": "text",
					"required": 1
				},
				{
					"key": "field_so_hero_description",
					"label": "Hero description",
					"name": "hero_description",
					"type": "textarea",
					"rows": 3,
					"new_lines": "",
					"required": 1
				},
				{
					"key": "field_so_hero_gradient_start",
					"label": "Gradient start color",
					"name": "hero_gradient_start",
					"type": "select",
					"required": 1,
					"return_format": "value",
					"choices": {
						"#0E6D77": "#0E6D77 (Brand Teal)",
						"#1ECAD3": "#1ECAD3 (Bright Cyan)",
						"#062B53": "#062B53 (Deep Navy)"
					}
				},
				{
					"key": "field_so_hero_gradient_middle",
					"label": "Gradient middle color",
					"name": "hero_gradient_middle",
					"type": "select",
					"required": 1,
					"return_format": "value",
					"choices": {
						"#062B53": "#062B53 (Deep Navy)",
						"#0A4E57": "#0A4E57 (Ocean Teal)",
						"#0E6D77": "#0E6D77 (Brand Teal)"
					}
				},
				{
					"key": "field_so_hero_gradient_end",
					"label": "Gradient end color",
					"name": "hero_gradient_end",
					"type": "select",
					"required": 1,
					"return_format": "value",
					"choices": {
						"#0A4E57": "#0A4E57 (Ocean Teal)",
						"#062B53": "#062B53 (Deep Navy)",
						"#0E6D77": "#0E6D77 (Brand Teal)"
					}
				},
				{
					"key": "field_so_hero_radial_opacity",
					"label": "Radial highlight opacity",
					"name": "hero_radial_highlight_opacity",
					"type": "select",
					"required": 1,
					"return_format": "value",
					"choices": {
						"0.16": "0.16 (Soft)",
						"0.22": "0.22 (Default)",
						"0.28": "0.28 (Strong)"
					}
				},
				{
					"key": "field_so_hero_dark_opacity",
					"label": "Dark overlay opacity",
					"name": "hero_dark_overlay_opacity",
					"type": "select",
					"required": 1,
					"return_format": "value",
					"choices": {
						"0.18": "0.18 (Soft)",
						"0.22": "0.22 (Default)",
						"0.28": "0.28 (Strong)"
					}
				},
				{
					"key": "field_so_hero_pattern_opacity",
					"label": "Pattern opacity",
					"name": "hero_pattern_opacity",
					"type": "select",
					"required": 1,
					"return_format": "value",
					"choices": {
						"0.06": "0.06 (Very subtle)",
						"0.10": "0.10 (Subtle)",
						"0.14": "0.14 (Visible)"
					}
				},
				{
					"key": "field_so_hero_pattern_mode",
					"label": "Hero pattern mode",
					"name": "hero_pattern_mode",
					"type": "select",
					"required": 1,
					"return_format": "value",
					"choices": {
						"registration_grid": "Registration grid (built-in SVG tile)",
						"custom_file": "Custom SVG/PNG tile (file upload)"
					}
				},
				{
					"key": "field_so_hero_pattern_custom_file",
					"label": "Custom pattern tile (SVG recommended)",
					"name": "hero_pattern_custom_file",
					"type": "file",
					"return_format": "url",
					"required": 1,
					"conditional_logic": [
						[
							{
								"field": "field_so_hero_pattern_mode",
								"operator": "==",
								"value": "custom_file"
							}
						]
					],
					"mime_types": "svg,xml,png,webp"
				}
			]
		},
